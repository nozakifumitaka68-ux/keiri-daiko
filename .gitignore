# ===================================
# 機密情報(絶対にコミット禁止)
# ===================================
.env
.env.*
!.env.example
*.key
*.pem
credentials.json
.streamlit/secrets.toml
*secret*.toml
*secret*.json
*secret*.yaml

# ===================================
# Python
# ===================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
ENV/
env/
*.egg-info/
.pytest_cache/

# ===================================
# データ(ローカル保管・流出防止)
# ===================================
data/
!data/.gitkeep

# サンプル領収書(機密情報含む可能性あり)
samples/receipts/*
!samples/receipts/.gitkeep

# ===================================
# IDE
# ===================================
.vscode/
.idea/
*.swp
*.swo

# ===================================
# OS
# ===================================
.DS_Store
Thumbs.db
desktop.ini

# ===================================
# ログ・一時ファイル
# ===================================
*.log
*.tmp
.cache/

# ===================================
# Node(他プロジェクトの残骸)
# ===================================
node_modules/
package-lock.json
package.json
