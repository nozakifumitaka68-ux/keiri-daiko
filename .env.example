# ===================================
# .env テンプレート(実値は .env に書く)
# ===================================

# OCRエンジン: auto / gemini / claude / stub
OCR_ENGINE=auto

# Google Gemini API(無料・推奨)
# 取得: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Anthropic Claude API(有料・最高精度)
# 取得: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# 後方互換: 1=強制スタブ
OCR_STUB_MODE=

# マネーフォワード
MF_MODE=mock
MF_CLIENT_ID=
MF_CLIENT_SECRET=
MF_REDIRECT_URI=http://localhost:8501/callback

# アプリパスワード
APP_PASSWORD=
