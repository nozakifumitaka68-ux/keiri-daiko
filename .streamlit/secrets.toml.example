# ===================================
# Streamlit Cloud Secrets テンプレート
# ===================================
#
# 実際のシークレットは Streamlit Cloud のダッシュボードで設定する。
# ローカル開発時は .streamlit/secrets.toml(.gitignore済)に書く。

# アプリのログインパスワード(友人共有用)
APP_PASSWORD = "your-secret-password-here"

# OCRエンジン選択(推奨: gemini)
OCR_ENGINE = "gemini"

# Google Gemini API(無料枠が大きい・推奨)
# 取得: https://aistudio.google.com/app/apikey
GEMINI_API_KEY = "AIza..."
GEMINI_MODEL = "gemini-2.5-flash"

# Anthropic Claude API(高精度・有料)を使う場合のみ
# ANTHROPIC_API_KEY = "sk-ant-xxxxxxxxxxxxxxxxxxxxx"

# マネーフォワード API(実API連携時のみ)
# MF_CLIENT_ID = ""
# MF_CLIENT_SECRET = ""
