# ===================================
# Streamlit Cloud Secrets テンプレート
# ===================================
#
# このファイル(.example)はGitにコミットしてOK。
# 実際のシークレットは「.streamlit/secrets.toml」(.gitignore済)に書くか、
# Streamlit Cloud のダッシュボードで設定する。
#
# 設定箇所:
#   - ローカル開発: .streamlit/secrets.toml にコピーして値を入れる
#   - Cloud デプロイ: アプリ設定 > Secrets に貼り付け

# アプリのログインパスワード(友人共有用)
# 例: "demo2026" のような推測されにくい英数字
APP_PASSWORD = "your-secret-password-here"

# Anthropic Claude API キー(本物OCR動かす場合のみ必要)
# スタブモード(OCR_STUB_MODE=1)で動かすなら不要
# ANTHROPIC_API_KEY = "sk-ant-xxxxxxxxxxxxxxxxxxxxx"

# マネーフォワード API(実API連携時のみ)
# MF_CLIENT_ID = ""
# MF_CLIENT_SECRET = ""
